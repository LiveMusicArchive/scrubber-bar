{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["es2022", "dom", "dom.iterable"],
    // Web Test Runner injects Mocha's describe/it/etc. as globals at runtime;
    // pull in @types/mocha so the test files typecheck against them.
    "types": ["mocha"],
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "importHelpers": true,
    "experimentalDecorators": true,
    // Lit's @property/@state decorators install reactive accessors on the
    // class prototype. Standard class fields (the default at target es2022+)
    // would redefine those as own properties and clobber the accessors,
    // silently breaking reactivity — so class fields stay as assignments.
    "useDefineForClassFields": false,
    "noEmit": true,
    "outDir": "dist",
    "rootDir": "."
  },
  "include": ["index.ts", "src/**/*.ts", "demo/**/*.ts", "test/**/*.ts"]
}
