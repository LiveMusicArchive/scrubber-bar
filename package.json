{
  "name": "@astralengineering/scrubber-bar",
  "version": "0.1.1",
  "description": "A Scrubber Bar LitElement for use in scrubbing through media",
  "author": "Astral Engineering",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "customElements": "custom-elements.json",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./custom-elements.json": "./custom-elements.json"
  },
  "files": [
    "dist",
    "custom-elements.json"
  ],
  "sideEffects": true,
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "publishConfig": {
    "registry": "https://registry.livemusicarchive.app"
  },
  "scripts": {
    "start": "vite",
    "build": "vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "analyze": "cem analyze",
    "lint": "eslint . && prettier \"**/*.{ts,js,mjs,html,md}\" --check",
    "format": "eslint . --fix && prettier \"**/*.{ts,js,mjs,html,md}\" --write",
    "test": "web-test-runner --coverage",
    "test:watch": "web-test-runner --watch",
    "prepare": "husky",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "lit": "^3"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.10.4",
    "@eslint/js": "^10.0.1",
    "@open-wc/testing": "^4.0.0",
    "@types/mocha": "^10.0.10",
    "@web/dev-server-esbuild": "^1.0.4",
    "@web/test-runner": "^0.20.2",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-lit": "^2.3.1",
    "eslint-plugin-wc": "^3.1.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "lit": "^3.3.3",
    "prettier": "^3.9.4",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3"
  },
  "prettier": {
    "singleQuote": true,
    "arrowParens": "avoid"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,mjs,html,md,json}": [
      "prettier --write"
    ]
  }
}
