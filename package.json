{
  "name": "@astralengineering/scrubber-bar",
  "version": "0.1.1",
  "description": "A Scrubber Bar LitElement for use in scrubbing through media",
  "author": "Astral Engineering",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "customElements": "custom-elements.json",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./custom-elements.json": "./custom-elements.json"
  },
  "files": [
    "dist",
    "custom-elements.json"
  ],
  "sideEffects": true,
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "registry": "https://registry.livemusicarchive.app"
  },
  "scripts": {
    "start": "vite",
    "build": "vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "analyze": "cem analyze",
    "lint": "eslint . && prettier \"**/*.{ts,js,mjs,html,md}\" --check",
    "format": "eslint . --fix && prettier \"**/*.{ts,js,mjs,html,md}\" --write",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "prepare": "husky",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "lit": "^3"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.10.4",
    "@eslint/js": "^9.39.2",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-lit": "^2.1.1",
    "eslint-plugin-wc": "^3.0.1",
    "globals": "^16.5.0",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "lit": "^3.3.2",
    "prettier": "^3.8.1",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.1",
    "vite": "^7.3.1",
    "vitest": "^4.1.10"
  },
  "prettier": {
    "singleQuote": true,
    "arrowParens": "avoid"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,mjs,html,md,json}": [
      "prettier --write"
    ]
  }
}
